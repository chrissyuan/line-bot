// 根據關鍵字搜尋（搜尋店名、地址、分類、子分類）
function searchFamilyEnvironment(keyword) {
  if (!keyword) return places;
  
  const lowerKeyword = keyword.toLowerCase();
  return places.filter(place => 
    place.name.toLowerCase().includes(lowerKeyword) ||
    place.address.toLowerCase().includes(lowerKeyword) ||
    place.category.toLowerCase().includes(lowerKeyword) ||
    place.subcategory.toLowerCase().includes(lowerKeyword)
  );
}

// 根據分類搜尋（景點或餐廳）
function searchByCategory(category) {
  if (!category) return places;
  const lowerCategory = category.toLowerCase();
  return places.filter(place => place.category.toLowerCase() === lowerCategory);
}

// 根據子分類搜尋
function searchBySubcategory(subcategory) {
  if (!subcategory) return places;
  const lowerSubcategory = subcategory.toLowerCase();
  return places.filter(place => place.subcategory.toLowerCase().includes(lowerSubcategory));
}

// 取得所有親子環境地點
function getAllFamilyEnvironment() {
  return places;
}

// 取得景點
function getAttractions() {
  return places.filter(place => place.category === '景點');
}

// 取得餐廳
function getRestaurants() {
  return places.filter(place => place.category === '餐廳');
}

// 取得數量
function getTotalCount() {
  return places.length;
}

// 取得景點數量
function getAttractionsCount() {
  return places.filter(place => place.category === '景點').length;
}

// 取得餐廳數量
function getRestaurantsCount() {
  return places.filter(place => place.category === '餐廳').length;
}

// 獲取單一地點詳細資訊（純文字版）
function getPlaceDetail(placeName) {
  const place = places.find(p => 
    p.name.includes(placeName) || 
    placeName.includes(p.name)
  );
  
  if (!place) return null;
  
  const categoryEmoji = place.category === '景點' ? '🏞️' : '🍽️';
  const subcategoryEmoji = getSubcategoryEmoji(place.subcategory);
  
  let detail = `${categoryEmoji} ${place.name}\n`;
  detail += `━━━━━━━━━━━━\n`;
  detail += `📂 ${place.category} ${subcategoryEmoji}${place.subcategory}\n`;
  detail += `📍 ${place.address}\n`;
  detail += `🕐 ${place.hours}\n`;
  if (place.phone) detail += `📞 ${place.phone}\n`;
  detail += `🔗 ${place.mapLink}`;
  
  return detail;
}

// 取得子分類表情符號
function getSubcategoryEmoji(subcategory) {
  const emojiMap = {
    '公園': '🌳',
    '體驗館': '🎮',
    '休閒農場': '🐮',
    '釣蝦場': '🦐',
    '生態館': '🐠',
    '親子館': '👶',
    '觀光工廠': '🏭',
    '學校': '📚',
    '中式餐廳': '🥢',
    '釣蝦餐廳': '🦐',
    '親子餐廳': '👪',
    '海鮮餐廳': '🦀',
    '咖啡廳': '☕',
    '泰式餐廳': '🍜',
    '寵物餐廳': '🐶',
    '快炒': '🍳',
    '景觀餐廳': '🏔️'
  };
  return emojiMap[subcategory] || '📍';
}

// 獲取單一地點詳細資訊（包含圖片）- 回傳 Line 訊息格式
