// 格式化親子環境訊息
function formatFamilyEnvironmentMessage(places, title = '親子環境') {
  if (!places || places.length === 0) {
    return '👨‍👩‍👧‍👦 找不到相關的親子環境地點\n\n💡 提示：\n• 輸入「親子環境」查看所有親子景點與餐廳\n• 輸入「親子環境 景點」只看景點\n• 輸入「親子環境 餐廳」只看餐廳\n• 輸入「親子環境 公園」只看公園類\n• 或直接輸入名稱搜尋特定地點';
  }

  let message = `👨‍👩‍👧‍👦 礁溪${title}列表\n`;
  message += '━━━━━━━━━━━━\n\n';
  
  const displayPlaces = places.slice(0, 30);
  
  displayPlaces.forEach((place, index) => {
    const emoji = place.category === '景點' ? '🏞️' : '🍽️';
    const subEmoji = getSubcategoryEmoji(place.subcategory);
    message += `${index + 1}. ${emoji} ${place.name}\n`;
    message += `   ${subEmoji} ${place.subcategory}\n`;
  });
  
  if (places.length > 30) {
    message += `\n📊 還有 ${places.length - 30} 個地點\n`;
    message += `💡 輸入「親子環境 景點」或「親子環境 餐廳」篩選`;
  } else {
    message += `\n📝 共 ${places.length} 個親子地點\n`;
    message += `   🏞️ 景點 ${getAttractionsCount()} 個 | 🍽️ 餐廳 ${getRestaurantsCount()} 間\n`;
    message += `💡 輸入「親子環境 公園」可依分類篩選`;
  }
  
  message += `\n━━━━━━━━━━━━\n🔍 例如：親子環境 水鹿咖啡 或 親子環境 公園`;
  
  return message;
}

// 取得分類統計
function getCategoryStats() {
  return {
    總數: places.length,
    景點: getAttractionsCount(),
    餐廳: getRestaurantsCount(),
    子分類: {
      公園: places.filter(p => p.subcategory === '公園').length,
      體驗館: places.filter(p => p.subcategory === '體驗館').length,
      休閒農場: places.filter(p => p.subcategory === '休閒農場').length,
      釣蝦場: places.filter(p => p.subcategory === '釣蝦場').length,
      生態館: places.filter(p => p.subcategory === '生態館').length,
      親子館: places.filter(p => p.subcategory === '親子館').length,
      觀光工廠: places.filter(p => p.subcategory === '觀光工廠').length,
      親子餐廳: places.filter(p => p.subcategory === '親子餐廳').length,
      咖啡廳: places.filter(p => p.subcategory === '咖啡廳').length,
      海鮮餐廳: places.filter(p => p.subcategory === '海鮮餐廳').length
    }
  };
}

