// 根據關鍵字搜尋（搜尋店名和地址）
function searchJiaoxiPlaces(keyword) {
  if (!keyword) return places;
  
  const lowerKeyword = keyword.toLowerCase();
  return places.filter(place => 
    place.name.toLowerCase().includes(lowerKeyword) ||
    place.address.toLowerCase().includes(lowerKeyword)
  );
}

// 根據分類搜尋
function searchJiaoxiPlacesByCategory(category) {
  if (!category) return places;
  
  const lowerCategory = category.toLowerCase();
  return places.filter(place => 
    place.category.toLowerCase().includes(lowerCategory)
  );
}

// 取得所有景點和餐廳
function getAllJiaoxiPlaces() {
  return places;
}

// 取得景點
function getAttractions() {
  return places.filter(place => place.category === '景點');
}

// 取得餐廳
function getRestaurants() {
  return places.filter(place => place.category === '餐廳');
}

// 取得數量
function getJiaoxiPlacesCount() {
  return places.length;
}

// 取得景點數量
function getAttractionsCount() {
  return places.filter(place => place.category === '景點').length;
}

// 取得餐廳數量
function getRestaurantsCount() {
  return places.filter(place => place.category === '餐廳').length;
}

// 獲取單一店家詳細資訊（純文字版）
function getJiaoxiPlaceDetail(placeName) {
  const place = places.find(p => 
    p.name.includes(placeName) || 
    placeName.includes(p.name)
  );
  
  if (!place) return null;
  
  let categoryEmoji = place.category === '景點' ? '🏞️' : '🍽️';
  
  let detail = `${categoryEmoji} ${place.name}\n`;
  detail += `━━━━━━━━━━━━\n`;
  detail += `📂 ${place.category}\n`;
  detail += `📍 ${place.address}\n`;
  detail += `🕐 ${place.hours}\n`;
  if (place.phone) detail += `📞 ${place.phone}\n`;
  detail += `🔗 ${place.mapLink}`;
  
  return detail;
}

// 獲取單一店家詳細資訊（包含圖片）- 回傳 Line 訊息格式
