            },
            {
              type: 'box',
              layout: 'vertical',
              margin: 'lg',
              spacing: 'sm',
              contents: [
                {
                  type: 'box',
                  layout: 'horizontal',
                  contents: [
                    {
                      type: 'text',
                      text: '📂',
                      size: 'sm'
                    },
                    {
                      type: 'text',
                      text: place.category,
                      size: 'sm',
                      wrap: true,
                      flex: 1
                    }
                  ]
                },
                {
                  type: 'box',
                  layout: 'horizontal',
                  contents: [
                    {
                      type: 'text',
                      text: '📍',
                      size: 'sm'
                    },
                    {
                      type: 'text',
                      text: place.address,
                      size: 'sm',
                      wrap: true,
                      flex: 1
                    }
                  ]
                },
                {
                  type: 'box',
                  layout: 'horizontal',
                  contents: [
                    {
                      type: 'text',
                      text: '🕐',
                      size: 'sm'
                    },
                    {
