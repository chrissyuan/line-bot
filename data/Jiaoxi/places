  const place = places.find(p => 
    p.name.includes(placeName) || 
    placeName.includes(p.name)
  );
  
  if (!place) return null;
  
  const categoryEmoji = place.category === '景點' ? '🏞️' : '🍽️';
  const textMessage = `${categoryEmoji} ${place.name}\n━━━━━━━━━━━━\n📂 ${place.category}\n📍 ${place.address}\n🕐 ${place.hours}\n🔗 ${place.mapLink}`;
  
