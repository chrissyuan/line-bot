}

// 格式化景點和餐廳訊息
function formatJiaoxiPlacesMessage(places, title = '景點與餐廳') {
  if (!places || places.length === 0) {
    return '🏞️ 找不到相關的景點或餐廳\n\n💡 提示：\n• 輸入「礁溪景點」查看所有景點\n• 輸入「礁溪餐廳」查看所有餐廳\n• 輸入「礁溪景點 名稱」搜尋特定景點\n• 輸入「礁溪餐廳 名稱」搜尋特定餐廳';
  }

  let message = `🏞️ 礁溪${title}列表\n`;
  message += '━━━━━━━━━━━━\n\n';
  
  const displayPlaces = places.slice(0, 30);
  
  displayPlaces.forEach((place, index) => {
    const emoji = place.category === '景點' ? '🏞️' : '🍽️';
    message += `${index + 1}. ${emoji} ${place.name}\n`;
  });
  
  if (places.length > 30) {
    message += `\n📊 還有 ${places.length - 30} 個地點\n`;
    message += `💡 輸入「礁溪景點 名稱」搜尋特定景點`;
  } else {
    message += `\n📝 共 ${places.length} 個地點\n`;
    message += `💡 輸入「礁溪景點 名稱」或「礁溪餐廳 名稱」搜尋詳細資訊`;
  }
  
  message += `\n━━━━━━━━━━━━\n🔍 例如：礁溪景點 甲鳥園 或 礁溪餐廳 里海咖啡`;
  
  return message;
}

