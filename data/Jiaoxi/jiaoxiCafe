  const emojiMap = {
    '特色咖啡': '☕',
    '甜點咖啡': '🍰',
    '茶屋': '🍵',
    '刨冰咖啡': '❄️',
    '校園咖啡': '📚',
    '連鎖咖啡': '☕',
    '景觀咖啡': '🏔️',
    '自家烘焙': '🔥',
    '書店咖啡': '📖',
    '親子咖啡': '👪',
    '寵物咖啡': '🐱'
  };
  return emojiMap[subcategory] || '☕';
}

