// 根據關鍵字搜尋
function searchCafe(keyword) {
  if (!keyword) return cafes;
  
  const lowerKeyword = keyword.toLowerCase();
  return cafes.filter(cafe => 
    cafe.name.toLowerCase().includes(lowerKeyword) ||
    cafe.address.toLowerCase().includes(lowerKeyword) ||
    cafe.subcategory.toLowerCase().includes(lowerKeyword)
  );
}

// 取得所有咖啡廳
function getAllCafes() {
  return cafes;
}

// 取得數量
function getCafeCount() {
  return cafes.length;
}

// 獲取單一咖啡廳詳細資訊
function getCafeDetail(cafeName) {
  const cafe = cafes.find(c => 
    c.name.includes(cafeName) || 
    cafeName.includes(c.name)
  );
  
  if (!cafe) return null;
  
  let detail = `☕ ${cafe.name}\n`;
  detail += `━━━━━━━━━━━━\n`;
  detail += `📍 ${cafe.address}\n`;
  detail += `🕐 ${cafe.hours}\n`;
  if (cafe.phone) detail += `📞 ${cafe.phone}\n`;
  detail += `🔗 ${cafe.mapLink}`;
  
  return detail;
}

// 格式化咖啡廳訊息
function formatCafeMessage(cafes, title = '咖啡廳') {
  if (!cafes || cafes.length === 0) {
    return '☕ 找不到相關的咖啡廳\n\n💡 提示：\n• 輸入「咖啡廳」查看所有咖啡廳\n• 輸入「下午茶」查看所有咖啡廳\n• 或直接輸入名稱搜尋（例如：星巴克）';
  }

  let message = `☕ 礁溪${title}列表\n`;
  message += '━━━━━━━━━━━━\n\n';
  
  const displayCafes = cafes.slice(0, 30);
  
  displayCafes.forEach((cafe, index) => {
    message += `${index + 1}. ${cafe.name}\n`;
  });
  
  if (cafes.length > 30) {
    message += `\n📊 還有 ${cafes.length - 30} 間咖啡廳\n`;
  } else {
    message += `\n📝 共 ${cafes.length} 間咖啡廳\n`;
  }
  
  message += `\n━━━━━━━━━━━━\n🔍 例如：星巴克 或 路易莎`;
  
  return message;
}

// 取得子分類表情符號（保留供其他功能使用）
