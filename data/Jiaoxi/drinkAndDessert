// 根據關鍵字搜尋
function searchDrinkAndDessert(keyword) {
  if (!keyword) return places;
  
  const lowerKeyword = keyword.toLowerCase();
  return places.filter(place => 
    place.name.toLowerCase().includes(lowerKeyword) ||
    place.address.toLowerCase().includes(lowerKeyword) ||
    place.category.toLowerCase().includes(lowerKeyword) ||
    place.subcategory.toLowerCase().includes(lowerKeyword)
  );
}

// 根據分類搜尋
function searchByCategory(category) {
  if (!category) return places;
  const lowerCategory = category.toLowerCase();
  return places.filter(place => place.category.toLowerCase() === lowerCategory);
}

// 取得所有地點
function getAllDrinkAndDessert() {
  return places;
}

// 取得飲料店
function getDrinkShops() {
  return places.filter(place => place.category === '飲料店');
}

// 取得咖啡廳
function getCafes() {
  return places.filter(place => place.category === '咖啡廳');
}

// 取得點心
function getDesserts() {
  return places.filter(place => place.category === '點心');
}

// 取得數量
function getTotalCount() {
  return places.length;
}

// 取得飲料店數量
function getDrinkShopsCount() {
  return places.filter(place => place.category === '飲料店').length;
}

// 取得咖啡廳數量
function getCafesCount() {
  return places.filter(place => place.category === '咖啡廳').length;
}

// 取得點心數量
function getDessertsCount() {
  return places.filter(place => place.category === '點心').length;
}

// 獲取單一地點詳細資訊
function getPlaceDetail(placeName) {
  const place = places.find(p => 
    p.name.includes(placeName) || 
    placeName.includes(p.name)
  );
  
  if (!place) return null;
  
  const categoryEmoji = getCategoryEmoji(place.category);
  const subcategoryEmoji = getSubcategoryEmoji(place.subcategory);
  
  let detail = `${categoryEmoji} ${place.name}\n`;
  detail += `━━━━━━━━━━━━\n`;
  detail += `📂 ${place.category} ${subcategoryEmoji}${place.subcategory}\n`;
  detail += `📍 ${place.address}\n`;
  detail += `🕐 ${place.hours}\n`;
  if (place.phone) detail += `📞 ${place.phone}\n`;
  detail += `🔗 ${place.mapLink}`;
  
  return detail;
}

