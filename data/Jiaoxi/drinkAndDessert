// 格式化訊息
function formatDrinkAndDessertMessage(places, title = '飲料點心下午茶') {
  if (!places || places.length === 0) {
    return '☕ 找不到相關的飲料、點心或咖啡廳\n\n💡 提示：\n• 輸入「飲料點心下午茶」查看所有店家\n• 或直接輸入名稱搜尋（例如：星巴克、柯氏蔥油餅）';
  }

  let message = `☕ 礁溪${title}列表\n`;
  message += '━━━━━━━━━━━━\n\n';
  
  const displayPlaces = places.slice(0, 30);
  
  displayPlaces.forEach((place, index) => {
    const emoji = getCategoryEmoji(place.category);
    const subEmoji = getSubcategoryEmoji(place.subcategory);
    message += `${index + 1}. ${emoji} ${place.name}\n`;
    message += `   ${subEmoji} ${place.subcategory}\n`;
  });
  
  if (places.length > 30) {
    message += `\n📊 還有 ${places.length - 30} 個店家\n`;
  } else {
    message += `\n📝 共 ${places.length} 個店家\n`;
    message += `   🥤 飲料店 ${getDrinkShopsCount()} 間 | ☕ 咖啡廳 ${getCafesCount()} 間 | 🍰 點心 ${getDessertsCount()} 個\n`;
  }
  
  message += `\n━━━━━━━━━━━━\n🔍 例如：星巴克 或 柯氏蔥油餅`;
  
  return message;
}

